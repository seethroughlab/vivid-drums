{
  "meta": {
    "title": "Drum Stack Foundation",
    "description": "Syncopated 16-step groove showcasing all six drum voices through a DrumSequencer.",
    "packages": ["vivid-drums", "vivid-sequencers"],
    "tags": ["drums", "stack", "layering", "sequencer"],
    "difficulty": "beginner",
    "domains": ["audio"]
  },
  "nodes": {
    "clock1": { "type": "Clock", "params": { "bpm": 122.0 } },
    "seq1": {
      "type": "DrumSequencer",
      "params": {
        "steps": 16,
        "swing": 0.12,
        "kick_0": 1.0, "kick_3": 1.0, "kick_6": 1.0, "kick_10": 1.0,
        "snare_4": 1.0, "snare_12": 1.0,
        "hat_0": 1.0, "hat_2": 1.0, "hat_4": 1.0, "hat_6": 1.0, "hat_8": 1.0, "hat_10": 1.0, "hat_12": 1.0, "hat_14": 1.0,
        "oh_0": 1.0,
        "clap_4": 1.0,
        "tom_13": 1.0, "tom_14": 1.0
      }
    },
    "kick1":  { "type": "DrumKick", "params": { "pitch": 58.0, "pitch_env": 230.0, "decay": 0.38, "click": 0.24, "volume": 0.45 } },
    "snare1": { "type": "DrumSnare", "params": { "pitch": 210.0, "tone": 0.45, "noise": 0.66, "tone_decay": 0.11, "noise_decay": 0.22, "snappy": 0.65, "volume": 0.26 } },
    "hat1":   { "type": "DrumHiHat", "params": { "decay": 0.06, "tone": 0.74, "ring": 0.42, "volume": 0.18 } },
    "clap1":  { "type": "DrumClap", "params": { "decay": 0.17, "tone": 0.66, "sloppy": 0.22, "tail": 0.16, "volume": 0.14 } },
    "tom1":   { "type": "DrumTom", "params": { "pitch": 95.0, "bend": 0.35, "decay": 0.28, "volume": 0.13 } },
    "cym1":   { "type": "DrumCymbal", "params": { "decay": 1.4, "tone": 0.52, "shimmer": 0.28, "sizzle": 0.22, "volume": 0.09 } },
    "aout":   { "type": "audio_out", "params": {} }
  },
  "connections": [
    { "from": "clock1/bar_phase", "to": "seq1/beat_phase" },
    { "from": "seq1/kick",  "to": "kick1/trigger" },
    { "from": "seq1/snare", "to": "snare1/trigger" },
    { "from": "seq1/hat",   "to": "hat1/trigger" },
    { "from": "seq1/clap",  "to": "clap1/trigger" },
    { "from": "seq1/tom",   "to": "tom1/trigger" },
    { "from": "seq1/oh",    "to": "cym1/trigger" },
    { "from": "kick1/output",  "to": "aout/input" },
    { "from": "snare1/output", "to": "aout/input" },
    { "from": "hat1/output",   "to": "aout/input" },
    { "from": "clap1/output",  "to": "aout/input" },
    { "from": "tom1/output",   "to": "aout/input" },
    { "from": "cym1/output",   "to": "aout/input" }
  ]
}
